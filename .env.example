# KOSPI Risk Watch local/deployment environment template.
# Copy this file to `.env`; keep real credentials out of git.
#
# Existing shell/systemd environment variables take precedence over `.env`.
# Set KOSPI_ENV_FILE=/path/to/file to load a different env file.

PORT=4173

# Server snapshot polling/cache cadence in ms (min 30000, max 1800000; default 300000).
# This is the real refresh lever: the UI auto-syncs its interval to this value, and
# force-refresh is rate-limited to it. For a 1-minute monitor during live market hours:
# POLLING_INTERVAL_MS=60000

# Macro context (optional, fail-closed). When a key is present it is merged onto the
# selected base adapter (e.g. yahoo-finance) via a composite. VIX and the prior US
# session feed the downside probability as *uncalibrated* adjustments (UI shows "미검증").
# FRED (https://fred.stlouisfed.org/docs/api/api_key.html):
# FRED_API_KEY=replace-with-fred-key
# FRED_VIX_SERIES=VIXCLS
# FRED_US_EQUITY_SERIES=SP500
# FRED_US10Y_SERIES=DGS10
# ECOS / Bank of Korea (https://ecos.bok.or.kr/api/) — stat codes are version-specific,
# supply {"statCode","cycle":"D|M|A","item"} per series:
# ECOS_API_KEY=replace-with-ecos-key
# ECOS_BASE_RATE_JSON={"statCode":"722Y001","cycle":"D","item":"0101000"}
# ECOS_USDKRW_JSON={"statCode":"731Y001","cycle":"D","item":"0000001"}
# ECOS_KTB3Y_JSON={"statCode":"817Y002","cycle":"D","item":"010200000"}
# MACRO_TIMEOUT_MS=5000

# KIS (한국투자증권) OpenAPI — real KOSPI200 futures 1-minute series + basis.
# When present, a `kospi200Futures` instrument is injected and the chart prefers it;
# basis is derived as futures - spot. Fails closed. TR ids / front-month code /
# field params are account/version specific — validate against your KIS account.
# The front-month KIS_FUTURES_CODE changes at each expiry.
# KIS_APP_KEY=replace-with-kis-app-key
# KIS_APP_SECRET=replace-with-kis-app-secret
# KIS_FUTURES_CODE=replace-with-front-month-code
# KIS_BASE_URL=https://openapi.koreainvestment.com:9443
# KIS_MINUTES_TR_ID=FHKIF03020200
# KIS_PRICE_TR_ID=FHMIF10000000
# KIS_CUST_TYPE=P
# KIS_MINUTES_PARAMS_JSON={"FID_HOUR_CLS_CODE":"60"}
# KIS_PRICE_PARAMS_JSON={}

# Leave MARKET_DATA_ADAPTER unset to keep the fail-closed public placeholder.
# For local deterministic UI checks only:
# MARKET_DATA_ADAPTER=mock
# MARKET_DATA_ADAPTER=mock-stale
# MARKET_DATA_ADAPTER=mock-error

# Public Yahoo/yfinance-style observation fallback while KRX API approval is absent.
# This provides KOSPI/KOSPI200/USDKRW chart proxies only; it is not KOSPI200 futures,
# not options/OI/short-selling data, and does not unlock liveReady.
# MARKET_DATA_ADAPTER=yahoo-finance
# YAHOO_FINANCE_KOSPI_SYMBOL=^KS11
# YAHOO_FINANCE_KOSPI200_SYMBOL=^KS200
# YAHOO_FINANCE_USDKRW_SYMBOL=KRW=X
# YAHOO_FINANCE_INTRADAY_RANGE=1d
# YAHOO_FINANCE_DAILY_RANGE=6mo
# YAHOO_FINANCE_TIMEOUT_MS=5000
# YAHOO_FINANCE_MAX_BODY_BYTES=786432

# Strict normalized upstream adapter, when an approved normalizer exists:
# MARKET_DATA_ADAPTER=json-http
# MARKET_DATA_URL=https://example.test/normalized-kospi-snapshot.json
# MARKET_DATA_SOURCE=approved-normalized-market-data
# MARKET_DATA_AUTH_HEADER_NAME=Authorization
# MARKET_DATA_AUTH_HEADER_VALUE=Bearer replace-me
# MARKET_DATA_TIMEOUT_MS=5000
# MARKET_DATA_MAX_BODY_BYTES=262144

# KRX OPEN API adapter, after KRX service approval and endpoint/API_ID mapping:
# MARKET_DATA_ADAPTER=krx-open-api
# KRX_OPEN_API_KEY=replace-with-your-auth-key
# KRX_OPEN_API_AUTH_HEADER_NAME=AUTH_KEY
# KRX_OPEN_API_KOSPI_DAILY_URL=https://openapi.krx.co.kr/replace/kospi-daily
# KRX_OPEN_API_KOSPI_DAILY_PARAMS_JSON={"API_ID":"replace-kospi-daily-api-id"}
# KRX_OPEN_API_KOSPI200_DAILY_URL=https://openapi.krx.co.kr/replace/kospi200-daily
# KRX_OPEN_API_KOSPI200_DAILY_PARAMS_JSON={"API_ID":"replace-kospi200-daily-api-id"}
# KRX_OPEN_API_FUTURES_URL=https://openapi.krx.co.kr/replace/kospi200-futures
# KRX_OPEN_API_FUTURES_PARAMS_JSON={"API_ID":"replace-futures-api-id"}
# KRX_OPEN_API_OPTIONS_URL=https://openapi.krx.co.kr/replace/kospi200-options
# KRX_OPEN_API_OPTIONS_PARAMS_JSON={"API_ID":"replace-options-api-id"}
# KRX_OPEN_API_INVESTOR_FLOW_URL=https://openapi.krx.co.kr/replace/investor-flow
# KRX_OPEN_API_INVESTOR_FLOW_PARAMS_JSON={"API_ID":"replace-investor-flow-api-id"}
# KRX_OPEN_API_HOLIDAY_CALENDAR_URL=https://openapi.krx.co.kr/replace/holiday-calendar
# KRX_OPEN_API_HOLIDAY_CALENDAR_PARAMS_JSON={"API_ID":"replace-holiday-calendar-api-id"}
# KRX_OPEN_API_COMMON_PARAMS_JSON={"reqType":"json"}
# KRX_OPEN_API_TIMEOUT_MS=5000
# KRX_OPEN_API_MAX_BODY_BYTES=524288

# These flags are capability claims only. They do not make readiness live unless
# the source/license pair is also present in the system-owned approval registry.
# KRX_OPEN_API_LIVE=true
# KRX_OPEN_API_APPROVED_PUBLIC=true
# KRX_OPEN_API_READINESS_ALLOWED=true
# KRX_OPEN_API_SOURCE_APPROVAL=replace-with-approval-id
# KRX_OPEN_API_LICENSE=replace-with-license-id
